<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_rental_period_tree" model="ir.ui.view">
        <field name="name">rental.period.tree</field>
        <field name="model">rental.period</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="code" />
                <field name="hours_per_unit" />
                <field name="active" />
            </tree>
        </field>
    </record>

    <record id="view_rental_period_form" model="ir.ui.view">
        <field name="name">rental.period.form</field>
        <field name="model">rental.period</field>
        <field name="arch" type="xml">
            <form string="Rental Period">
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="code" />
                        <field name="hours_per_unit" />
                        <field name="sequence" />
                        <field name="active" />
                    </group>
                    <separator string="Notes" />
                    <p class="oe_grey">
                        <i>
              Standard hours per unit is used to convert a rental duration to hours.
              (e.g. HOUR=1, DAY=24, WEEK=168, MONTH≈730, YEAR≈8760)
            </i>
                    </p>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_rental_period_search" model="ir.ui.view">
        <field name="name">rental.period.search</field>
        <field name="model">rental.period</field>
        <field name="arch" type="xml">
            <search string="Search Rental Periods">
                <field name="name" />
                <field name="code" />
                <filter
                    string="Active"
                    name="active"
                    domain="[('active','=',True)]"
                    help="Active periods"
                />
                <filter
                    string="Archived"
                    name="inactive"
                    domain="[('active','=',False)]"
                />
                <group expand="0" string="Group By">
                    <filter
                        string="Active"
                        name="group_active"
                        context="{'group_by':'active'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <record id="action_rental_periods" model="ir.actions.act_window">
        <field name="name">Rental Period</field>
        <field name="res_model">rental.period</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_rental_periods"
        parent="sale.prod_config_main"
        action="action_rental_periods"
        sequence="11"
    />
</odoo>
