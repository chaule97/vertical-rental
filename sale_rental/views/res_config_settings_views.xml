<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form_sale_rental" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.sale.stock.sale</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@id='connectors_setting_container']" position="after">
                <h2 class="mt32">Sale Rental</h2>
                <div
                    class="row mt16 o_settings_container"
                    name="sale_rental_setting_container"
                >
                    <div class="col-xs-12 col-md-6 o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="send_return_reminder" />
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="send_return_reminder" />
                            <div class="text-muted">
                                Send an email reminder to customers before their rental is due for return.
                            </div>
                            <div
                                class="content-group"
                                attrs="{'invisible': [('send_return_reminder', '=', False)]}"
                            >
                                <div class="row mt16">
                                    <label
                                        for="reminder_days"
                                        class="col-md-6 o_light_label"
                                    />
                                    <field name="reminder_days" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
