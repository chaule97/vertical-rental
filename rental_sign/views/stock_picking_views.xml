<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_picking_form_inherit_rental_sign" model="ir.ui.view">
        <field name="name">stock.picking.form.rental.sign</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">

            <!-- Make sure fields used in attrs exist in the view (Odoo 16 requirement) -->
            <xpath expr="//header" position="inside">
                <field name="picking_type_code" invisible="1" />
                <field name="is_rental_invoice" invisible="1" />
                <field name="delivery_staff_signed" invisible="1" />
                <field name="delivery_customer_signed" invisible="1" />
                <field name="delivery_sign_request_id" invisible="1" />
                <field name="return_staff_signed" invisible="1" />
            </xpath>

            <xpath expr="//header/button[@name='button_validate'][1]" position="before">

                <button
                    name="action_staff_sign_delivery"
                    string="Add Deliveryman's Signature"
                    type="object"
                    class="oe_highlight"
                    attrs="{'invisible': ['|','|','|',
                        ('picking_type_code','!=','outgoing'),
                        ('is_rental_invoice','=',False),
                        ('state','not in',['confirmed','assigned','waiting']),
                        ('delivery_staff_signed','=',True)
                    ]}"
                />

                <button
                    name="action_customer_sign_delivery"
                    string="Add Customer's Signature"
                    type="object"
                    class="oe_highlight"
                    attrs="{'invisible': ['|',
                        '&amp;',
                            ('picking_type_code','!=','outgoing'),
                            ('delivery_sign_request_id','=',False),
                        ('delivery_customer_signed','=',True)
                    ]}"
                />

                <button
                    name="action_staff_sign_receipt"
                    string="Add Staff's Signature"
                    type="object"
                    class="oe_highlight"
                    attrs="{'invisible': ['|','|','|',
                        ('picking_type_code','!=','incoming'),
                        ('is_rental_invoice','=',False),
                        ('state','not in',['confirmed','assigned','waiting']),
                        ('return_staff_signed','=',True)
                    ]}"
                />

            </xpath>
        </field>
    </record>
</odoo>
