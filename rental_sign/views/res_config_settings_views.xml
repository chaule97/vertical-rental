<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form_rental_sign" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.rental.sign</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@id='connectors_setting_container']" position="after">
                <h2>Rental Sign</h2>
                <div class="row mt16 o_settings_container" name="rental_sign">
                    <div
                        class="col-12 col-lg-6 o_setting_box"
                        id="rental_delivery_report_setting"
                    >
                        <div class="o_setting_left_pane">
                        </div>
                        <div class="o_setting_right_pane">
                            <label
                                for="rental_delivery_report_id"
                                string="Delivery Report for Signature"
                            />
                            <div class="text-muted">
                                Select the PDF Delivery report that will be exported and sent for signature when delivering rented items.
                            </div>
                            <div class="content-group">
                                <div class="mt16">
                                    <field
                                        name="rental_delivery_report_id"
                                        class="o_light_label"
                                    />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div
                        class="col-12 col-lg-6 o_setting_box"
                        id="rental_return_report_setting"
                    >
                        <div class="o_setting_left_pane">
                        </div>
                        <div class="o_setting_right_pane">
                            <label
                                for="rental_return_report_id"
                                string="Return Report for Signature"
                            />
                            <div class="text-muted">
                                Select the PDF Return report that will be exported and sent for signature when receiving returned items.
                            </div>
                            <div class="content-group">
                                <div class="mt16">
                                    <field
                                        name="rental_return_report_id"
                                        class="o_light_label"
                                    />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
