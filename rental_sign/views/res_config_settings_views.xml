<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form_rental_sign" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.rental.sign</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@id='connectors_setting_container']" position="after">
                <block title="Rental Sign" name="rental_sign">
                    <setting
                        id="rental_delivery_report_setting"
                        help="Select the PDF Delivery report that will be exported and sent for signature when delivering rented items."
                    >
                        <field name="rental_delivery_report_id" />
                    </setting>

                    <setting
                        id="rental_return_report_setting"
                        help="Select the PDF Return report that will be exported and sent for signature when receiving returned items."
                    >
                        <field name="rental_return_report_id" />
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
